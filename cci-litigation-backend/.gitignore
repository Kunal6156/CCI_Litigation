# Django Backend Environment Variables for Development

# !!! IMPORTANT: These values are for LOCAL DEVELOPMENT ONLY.
# For production deployment, you MUST replace these with truly secure, unique values
# and set them directly in your hosting environment (e.g., Docker secrets, cloud platform configs).

# Django Secret Key: Used for cryptographic signing. Crucial for security.
# You can generate a good one by opening a Python shell (after activating venv)
# and running: `from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())`
DJANGO_SECRET_KEY='xq^2o%ap3v7-5wl7a*_s4c4fzpf54nwvh8elx!06wa)44p_#$x'
# Debug Mode: Set to True for development (shows detailed errors). Set to False for production.
DJANGO_DEBUG=True

# Allowed Hosts: Domain names your Django server will serve requests from.
# '127.0.0.1' and 'localhost' for local development.
# In production, replace this with your actual domain(s), e.g., 'api.yourdomain.com'
DJANGO_ALLOWED_HOSTS='127.0.0.1,localhost'

# PostgreSQL Database Configuration
# These must match the database and user you created in PostgreSQL (e.g., via pgAdmin4).
DB_NAME='cci_litigation_db'
DB_USER='cci_user'
DB_PASSWORD='kunal123' 
DB_HOST='localhost'
DB_PORT='5432'

# CORS (Cross-Origin Resource Sharing) Allowed Origins
# This lists the URL(s) from which your frontend is allowed to make requests to this backend.
# For local development, this is typically your React development server.
# In production, this will be your deployed frontend URL (e.g., 'https://app.yourdomain.com').
# Multiple URLs should be comma-separated, with no spaces in between.
CORS_ALLOWED_ORIGINS='http://localhost:3000'